{
  "name": "XANCLD",
  "version": "1.0.0",
  "description": "XANCLD — Stream anime on Cloudflare Workers Free tier (Hono + Vite + React)",
  "private": true,
  "type": "module",
  "license": "MIT",
  "keywords": [
    "anime",
    "streaming",
    "cloudflare-workers",
    "hono",
    "vite",
    "react",
    "tailwindcss",
    "anilist",
    "allanime",
    "free-tier"
  ],
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler dev --port 3003",
    "build": "vite build",
    "build:worker": "wrangler deploy --dry-run --outdir=dist-worker",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hls.js": "^1.6.16",
    "hono": "^4.6.0",
    "lucide-react": "^0.525.0",
    "motion": "^12.42.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.0.2",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^6.0.0",
    "typescript": "^5",
    "tailwindcss": "^4",
    "@tailwindcss/vite": "^4.0.0",
    "wrangler": "^4.105.0",
    "@cloudflare/workers-types": "^4.20250101.0"
  },
  "engines": {
    "node": ">=18"
  }
}
